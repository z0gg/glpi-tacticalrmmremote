msgid "TacticalRMM settings"
msgstr "Paramètres TacticalRMM"

msgid "TacticalRMM base URL"
msgstr "URL de base TacticalRMM"

msgid "Open in TacticalRMM"
msgstr "Ouvrir dans TacticalRMM"

msgid "Open TacticalRMM Take Control session in a new tab"
msgstr "Ouvrir une session TacticalRMM Take Control dans un nouvel onglet"

msgid "Remote URL template"
msgstr "Modèle d'URL distante"

msgid "Use {id} for URL-encoded ID or {raw_id} for raw value. Put a full URL to support MeshCentral links."
msgstr "Utilisez {id} pour un identifiant encodé ou {raw_id} pour la valeur brute. Vous pouvez aussi mettre une URL complète pour MeshCentral."

msgid "Detected remote identifier"
msgstr "Identifiant distant détecté"

msgid "TacticalRMM remote access"
msgstr "Accès distant TacticalRMM"

msgid "Missing or invalid Computer ID."
msgstr "Identifiant d'ordinateur manquant ou invalide."

msgid "Computer not found."
msgstr "Ordinateur introuvable."

msgid "No TacticalRMM remote identifier was found for this Computer."
msgstr "Aucun identifiant TacticalRMM n'a été trouvé pour cet ordinateur."

msgid "Target URL points to an API or inventory endpoint."
msgstr "L'URL cible pointe vers un endpoint d'API ou d'inventaire."

msgid "Target URL host does not match the configured TacticalRMM base URL."
msgstr "L'hote de l'URL cible ne correspond pas a l'URL de base TacticalRMM configuree."

msgid "Unable to build a valid TacticalRMM URL from the detected identifier."
msgstr "Impossible de construire une URL TacticalRMM valide a partir de l'identifiant detecte."

msgid "The generated remote URL looks unsafe and was not opened automatically."
msgstr "L'URL distante generee semble non sure et n'a pas ete ouverte automatiquement."

msgid "Remote launch blocked"
msgstr "Ouverture distante bloquee"

msgid "Resolved remote identifier"
msgstr "Identifiant distant resolu"

msgid "Generated remote URL"
msgstr "URL distante generee"

msgid "Reason"
msgstr "Raison"

msgid "Back to Computer"
msgstr "Retour a l'ordinateur"

msgid "Open anyway"
msgstr "Ouvrir quand meme"

msgid "File configuration override is active: %s"
msgstr "La configuration fichier est active : %s"

msgid "Config file path: %s"
msgstr "Chemin du fichier de configuration : %s"
